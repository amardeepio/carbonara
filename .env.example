# ---------------------------------------------------------------------------
# Carbonara environment variables
# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is git-ignored and must NEVER be committed.
# Every integration is OPTIONAL — the app runs fully on built-in India data,
# rule-based insights, and an in-memory store when these are left blank.
# ---------------------------------------------------------------------------

# Groq LLM — powers the personalized natural-language insights.
# Get a key at https://console.groq.com/keys
# If unset, the assistant falls back to deterministic rule-based recommendations.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Carbon Interface — optional live emission factors (https://www.carboninterface.com).
# Free tier, works with any email. Used to price the electricity activity live.
# If unset, the app uses the built-in India-specific factors in src/lib/emissions.ts.
CARBON_INTERFACE_API_KEY=
# ISO country code for electricity estimates (default: in). Set to a supported
# country if India is unavailable on your plan; otherwise it falls back to built-in.
CARBON_INTERFACE_COUNTRY=in

# MongoDB — persistent storage for users and logged activities.
# Use a MongoDB Atlas free-tier cluster: https://www.mongodb.com/atlas
# If unset, an in-memory store is used (data resets when the server restarts).
MONGODB_URI=
MONGODB_DB=carbonara

# Sessions — secret used to sign the httpOnly session cookie.
# Generate one with: openssl rand -hex 32
# If unset, an ephemeral secret is used (sessions reset on server restart).
SESSION_SECRET=

# Google sign-in (optional) — OAuth "Web application" client id from
# https://console.cloud.google.com/apis/credentials (add your origin, e.g.
# http://localhost:3000, to "Authorized JavaScript origins"; no secret needed —
# the app uses Google Identity Services ID tokens, verified server-side).
# If unset, onboarding offers guest sign-in only.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google Cloud Translation API key (build-time only): used by
# `npm run translate` to regenerate src/lib/messages/{hi,bn,gu,ta}.json.
# Not needed at runtime — generated translations are committed.
GOOGLE_TRANSLATE_API_KEY=
